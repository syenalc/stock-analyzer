# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key_here

# X (Twitter) API - 必須
X_BEARER_TOKEN=your_x_bearer_token_here

# 対象銘柄
TARGET_TICKERS=AAPL,TSLA,NVDA,MSFT

# Xユーザー → 銘柄マッピング (JSON形式)
#   "ALL" を指定すると全TARGET_TICKERSに紐づく
#   例: elonmusk のツイートは TSLA, cathiedwood は TSLA と ARKK
X_USER_MAP={"elonmusk":["TSLA"],"cathiedwood":["TSLA","NVDA"],"unusual_whales":["ALL"],"jimcramer":["ALL"]}

# 何日前までのツイートを取得するか（例: 7 = 過去1週間）
X_FETCH_DAYS=7

# 1ユーザーあたりの最大取得件数（上限100）※多投稿アカウント対策
X_MAX_RESULTS=100
