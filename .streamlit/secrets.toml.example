# Streamlit Cloud にデプロイするときは、このファイルの中身を
# Streamlit Cloud の Settings → Secrets に貼り付ける（ファイル自体はpushしない）

ANTHROPIC_API_KEY = "sk-ant-..."

SUPABASE_URL = "https://xxxxx.supabase.co"
SUPABASE_KEY = "sb_secret_..."

X_BEARER_TOKEN = "AAAAA..."
X_FETCH_DAYS = "7"
X_MAX_RESULTS = "100"

TARGET_TICKERS = "SNDU,MUU"

# パスワード認証（公開URLを他人に使われないように）
APP_PASSWORD = "your_strong_password_here"
